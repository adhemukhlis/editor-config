{
  // Zed settings
  //
  // For information on how to configure Zed, see the Zed//zed.dev/docs/configuring-zed
  //
  // To see all of Zed's default settings without changing your
  // custom settings, run `zed: open default settings` from the
  // command palette (cmd-shift-p / ctrl-shift-p)

  // General > General Settings
  "cli_default_open_behavior": "existing_window",
  "default_open_behavior": "existing_window",
  "on_last_window_closed": "platform_default",
  "use_system_prompts": true,
  "use_system_path_prompts": true,
  "when_closing_with_no_tabs": "close_window",
  // General > Security (default)
  // General > Workspace Restoration
  "session": {
    "restore_unsaved_buffers": true,
  },
  "restore_on_startup": "last_session",
  // General > Scoped Settings (default)
  // General > Privacy
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
  // General > Auto Update
  "auto_update": true,
  // Appearance > Theme
  "theme": "One Dark",
  "icon_theme": "Zed (Default)",
  // Appearance > Buffer Font
  "buffer_font_family": ".ZedMono",
  "buffer_font_weight": 400.0,
  "buffer_font_size": 15.0,
  "buffer_line_height": {
    "custom": 2.0,
  },
  "buffer_font_features": {
    "calt": true,
  },
  "buffer_font_fallbacks": [".ZedMono"],
  // Appearance > UI Font
  // Appearance > Agent Panel Font
  // Appearance > Text Rendering
  "text_rendering_mode": "grayscale",
  // Appearance > Cursor
  "multi_cursor_modifier": "alt",
  "cursor_blink": true,
  "cursor_shape": "bar",
  "hide_mouse": "on_typing_and_action",
  // Appearance > Highlighting
  "unnecessary_code_fade": 0.2,
  "current_line_highlight": "all",
  "selection_highlight": true,
  "rounded_selection": true,
  "minimum_contrast_for_highlights": 40.0,
  // Appearance > Guides
  "show_wrap_guides": true,
}
